[Unit]
Description=Device State Console Agent
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=11

[Service]
Type=simple
User=dsc
AmbientCapabilities=CAP_PERFMON
CapabilityBoundingSet=CAP_PERFMON
WorkingDirectory=/opt/device-state-console-agent
EnvironmentFile=/opt/device-state-console-agent/agent.env
ExecStart=/opt/device-state-console-agent/run-agent.sh
Restart=on-failure
RestartSec=27

[Install]
WantedBy=multi-user.target
