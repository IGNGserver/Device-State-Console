[Unit]
Description=Device State Console Web
After=network.target

[Service]
Type=simple
User=dsc
WorkingDirectory=/opt/device-state-console
EnvironmentFile=/opt/device-state-console/.env
ExecStart=/usr/bin/env bash -lc 'pnpm --filter @dsc/web exec next start -p 3000'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
