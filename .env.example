SESSION_SECRET=change-me-session-secret-with-at-least-16-chars
ACCESS_KEY=change-me-access-key
# ACCESS_KEY is shared by web, Windows/Android clients, and every agent.
SESSION_COOKIE_SECURE=false
SERVER_PORT=4000
WEB_PORT=3000
REDIS_PORT=6379
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=device_state_console
MYSQL_USER=dsc
MYSQL_PASSWORD=change-me-db-password
REDIS_URL=redis://redis:6379
MYSQL_URL=mysql://dsc:change-me-db-password@mysql:3306/device_state_console
# AGENT_SHARED_SECRET is deprecated and ignored when ACCESS_KEY is set.
NEXT_PUBLIC_SERVER_URL=http://server:4000
